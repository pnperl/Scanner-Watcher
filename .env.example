# PostgreSQL connection string
# Free options: https://neon.tech  or  https://supabase.com
DATABASE_URL=postgresql://user:password@host:5432/dbname?sslmode=require

# Telegram bot — create one via @BotFather on Telegram
TELEGRAM_BOT_TOKEN=123456789:ABCdefGHIjklMNOpqrSTUvwxYZ

# Telegram chat/channel ID to send alerts to
# For a group/channel, get it from https://api.telegram.org/bot<TOKEN>/getUpdates
TELEGRAM_CHAT_ID=-1001234567890

# Session secret — any random string (used for future auth)
SESSION_SECRET=change-me-to-a-long-random-string
